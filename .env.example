# Anthropic API Key (verplicht)
# Vraag een key aan via https://platform.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OSRM server (optioneel - standaard: openrouteservice demo server)
# Voor productie: draai je eigen OSRM instance op 192.168.4.105
OSRM_BASE_URL=http://router.project-osrm.org

# App instellingen
APP_TITLE=AP06 Planner
DEBUG=false

# Pad naar de SQLite database (relatief aan projectroot)
DB_PATH=data/ap06.db

# Mendrix Custom Link SOAP-koppeling (optioneel — voor order-check)
MENDRIX_SOAP_URL=https://customlink.jouwbedrijf.nl:5564/soap/ICustomLinkSoap
MENDRIX_SOAP_USER=jouw-soap-gebruikersnaam
MENDRIX_SOAP_PASS=jouw-soap-wachtwoord

# Google Drive integratie (optioneel — voor xlsx-upload bij WhatsApp samenvatting)
# Token: eenmalig aanmaken via python test_gdrive_oauth.py (OAuth2 Desktop flow)
# Folder ID: te vinden in de URL van de gedeelde Drive-map (/folders/<ID>)
GDRIVE_TOKEN_JSON=credentials/gdrive_token.json
GDRIVE_FOLDER_ID=jouw-google-drive-folder-id
# TinyURL API token voor URL-verkorting met Bearer auth (optioneel — zonder token: anonieme fallback)
# Aanmaken via https://tinyurl.com/app/settings/api — permission: alleen "Create TinyURL"
TINYURL_API_TOKEN=jouw-tinyurl-api-token

# TextMeBot WhatsApp integratie (optioneel — voor automatische samenvatting)
# Registreer op https://textmebot.com en voeg je WhatsApp-nummer toe als kanaal.
TEXTMEBOT_API_KEY=jouw-textmebot-api-key
TEXTMEBOT_ONTVANGER=+31612345678
