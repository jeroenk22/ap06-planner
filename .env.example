# Anthropic API Key (verplicht)
# Vraag een key aan via https://platform.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OSRM server (optioneel - standaard: openrouteservice demo server)
# Voor productie: draai je eigen OSRM instance op 192.168.4.105
OSRM_BASE_URL=http://router.project-osrm.org

# App instellingen
APP_TITLE=AP06 Planner
DEBUG=false

# Pad naar de SQLite database (relatief aan projectroot)
DB_PATH=data/ap06.db

# Mendrix Custom Link SOAP-koppeling (optioneel — voor order-check)
MENDRIX_SOAP_URL=https://customlink.jouwbedrijf.nl:5564/soap/ICustomLinkSoap
MENDRIX_SOAP_USER=jouw-soap-gebruikersnaam
MENDRIX_SOAP_PASS=jouw-soap-wachtwoord
